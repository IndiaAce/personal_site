---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Luke Wescott — Threat Detection Engineer',
  description = 'Luke Wescott — Threat Detection Engineer at Sublime Security. Building ML-driven detection systems that catch what rules miss.',
} = Astro.props;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/resume', label: 'Résumé' },
  { href: '/blog', label: 'Blog' },
  { href: '/github', label: 'GitHub' },
  { href: '/now', label: 'Now' },
];

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <!-- Set theme before paint to avoid flash -->
    <script is:inline>
      (function () {
        try {
          var t = localStorage.getItem('theme');
          if (!t)
            t = matchMedia('(prefers-color-scheme: dark)').matches
              ? 'dark'
              : 'light';
          document.documentElement.setAttribute('data-theme', t);
        } catch (e) {}
      })();
    </script>
  </head>
  <body>
    <!-- grid spotlight revealed around the pointer (behind content) -->
    <div class="rt-grid" id="rt-grid" aria-hidden="true"></div>

    <!-- reticle / scope HUD (pointer-driven, never blocks clicks) -->
    <div class="rt" id="rt" aria-hidden="true">
      <div class="rt-lock" id="rt-lock">
        <span></span><span></span><span></span><span></span>
      </div>
      <div class="rt-line rt-line--h"></div>
      <div class="rt-line rt-line--v"></div>
      <div class="rt-scope"></div>
      <div class="rt-hud">
        <div>SCAN · <span id="rt-status">CLEAR</span></div>
        <div class="rt-coords" id="rt-coords">0000, 0000</div>
      </div>
    </div>

    <Header navLinks={navLinks} isActive={isActive} />

    <main>
      <slot />
    </main>

    <Footer />

    <!-- Full-screen brutalist overlay nav (mobile) -->
    <div class="overlay" id="overlay" aria-hidden="true">
      <nav class="overlay__nav">
        {
          navLinks.map((l, i) => (
            <a class="overlay__link" href={l.href}>
              <span class="overlay__num">
                {String(i + 1).padStart(2, '0')}
              </span>
              {l.label}
            </a>
          ))
        }
      </nav>
    </div>

    <script is:inline>
      (function () {
        var btn = document.getElementById('menu-btn');
        var overlay = document.getElementById('overlay');
        var burger = document.getElementById('burger');
        var open = false;
        function setMenu(v) {
          open = v;
          overlay.classList.toggle('overlay--open', v);
          overlay.setAttribute('aria-hidden', String(!v));
          burger && burger.classList.toggle('burger--open', v);
          if (btn) btn.setAttribute('aria-expanded', String(v));
          document.body.style.overflow = v ? 'hidden' : '';
        }
        btn && btn.addEventListener('click', function () { setMenu(!open); });
        overlay &&
          overlay.querySelectorAll('a').forEach(function (a) {
            a.addEventListener('click', function () { setMenu(false); });
          });
        document.addEventListener('keydown', function (e) {
          if (e.key === 'Escape' && open) setMenu(false);
        });

        // theme toggle
        var tbtns = document.querySelectorAll('[data-theme-toggle]');
        function curTheme() {
          return document.documentElement.getAttribute('data-theme') || 'light';
        }
        function syncIcons() {
          var dark = curTheme() === 'dark';
          tbtns.forEach(function (b) {
            var icon = b.querySelector('[data-theme-icon]');
            var lbl = b.querySelector('[data-theme-label]');
            if (icon) icon.textContent = dark ? '☀' : '☾';
            if (lbl) lbl.textContent = dark ? 'Light' : 'Dark';
          });
        }
        tbtns.forEach(function (b) {
          b.addEventListener('click', function () {
            var next = curTheme() === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            try { localStorage.setItem('theme', next); } catch (e) {}
            syncIcons();
          });
        });
        syncIcons();
      })();
    </script>

    <!-- reticle: guarded to fine pointers + motion; sets CSS vars on pointermove -->
    <script is:inline>
      (function () {
        var fine = matchMedia('(pointer: fine)');
        var noMotion = matchMedia('(prefers-reduced-motion: reduce)');
        var rt = document.getElementById('rt');
        var grid = document.getElementById('rt-grid');
        var lock = document.getElementById('rt-lock');
        var statusEl = document.getElementById('rt-status');
        var coordsEl = document.getElementById('rt-coords');
        var root = document.documentElement;

        var on = false, bound = false, raf = 0;
        var pmx = 0, pmy = 0, pTarget = null, pRect = null;

        function pad(n) {
          return String(Math.max(0, Math.round(n))).padStart(4, '0');
        }

        function flush() {
          raf = 0;
          root.style.setProperty('--rx', pmx + 'px');
          root.style.setProperty('--ry', pmy + 'px');
          coordsEl.textContent = pad(pmx) + ', ' + pad(pmy);
          if (pRect) {
            lock.style.opacity = '1';
            lock.style.left = (pRect.left - 7) + 'px';
            lock.style.top = (pRect.top - 7) + 'px';
            lock.style.width = (pRect.width + 14) + 'px';
            lock.style.height = (pRect.height + 14) + 'px';
            statusEl.textContent = 'LOCKED';
            statusEl.style.color = '#ff5f57';
          } else {
            lock.style.opacity = '0';
            statusEl.textContent = 'CLEAR';
            statusEl.style.color = 'var(--accent-live)';
          }
        }

        function move(e) {
          pmx = e.clientX;
          pmy = e.clientY;
          var t = e.target && e.target.closest ? e.target.closest('[data-target]') : null;
          pTarget = t;
          pRect = t ? t.getBoundingClientRect() : null;
          if (!raf) raf = requestAnimationFrame(flush);
        }

        function enable() {
          if (bound) return;
          bound = true;
          root.classList.add('reticle-active');
          rt.style.display = 'block';
          grid.style.display = 'block';
          window.addEventListener('pointermove', move, { passive: true });
        }
        function disable() {
          if (!bound) return;
          bound = false;
          root.classList.remove('reticle-active');
          rt.style.display = 'none';
          grid.style.display = 'none';
          window.removeEventListener('pointermove', move);
          if (raf) { cancelAnimationFrame(raf); raf = 0; }
        }
        function sync() {
          on = fine.matches && !noMotion.matches;
          if (on) enable(); else disable();
        }

        sync();
        fine.addEventListener('change', sync);
        noMotion.addEventListener('change', sync);
      })();
    </script>

    <style>
      /* ---- reticle / scope layer ---- */
      :root { --rx: 50%; --ry: 50%; }

      /* keep page content above the grid spotlight */
      main { position: relative; z-index: 1; }

      .rt-grid {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
        background-image:
          linear-gradient(var(--line) 1px, transparent 1px),
          linear-gradient(90deg, var(--line) 1px, transparent 1px);
        background-size: 48px 48px;
        opacity: .85;
        -webkit-mask-image: radial-gradient(circle 230px at var(--rx) var(--ry), #000, transparent 72%);
        mask-image: radial-gradient(circle 230px at var(--rx) var(--ry), #000, transparent 72%);
      }

      .rt { display: none; }
      .rt-line {
        position: fixed;
        background: var(--accent);
        opacity: .28;
        z-index: 9044;
        pointer-events: none;
      }
      .rt-line--h { left: 0; top: var(--ry); width: 100vw; height: 1px; }
      .rt-line--v { left: var(--rx); top: 0; width: 1px; height: 100vh; }
      .rt-scope {
        position: fixed;
        left: var(--rx);
        top: var(--ry);
        width: 46px;
        height: 46px;
        transform: translate(-50%, -50%);
        border: 1.5px solid var(--accent);
        border-radius: 50%;
        z-index: 9045;
        pointer-events: none;
      }
      .rt-hud {
        position: fixed;
        left: var(--rx);
        top: var(--ry);
        transform: translate(20px, 20px);
        z-index: 9046;
        pointer-events: none;
        font-family: var(--font-mono);
        font-size: 10.5px;
        letter-spacing: .06em;
        line-height: 1.5;
        white-space: nowrap;
        background: var(--ink);
        color: var(--bg);
        padding: 6px 10px;
        border-radius: 4px;
      }
      .rt-coords { opacity: .7; }
      .rt-lock {
        position: fixed;
        left: 0; top: 0; width: 0; height: 0;
        opacity: 0;
        z-index: 9040;
        pointer-events: none;
        transition: all .12s cubic-bezier(.2, .8, .2, 1);
      }
      .rt-lock span { position: absolute; width: 13px; height: 13px; }
      .rt-lock span:nth-child(1) { left: -1px; top: -1px; border-left: 2px solid var(--accent); border-top: 2px solid var(--accent); }
      .rt-lock span:nth-child(2) { right: -1px; top: -1px; border-right: 2px solid var(--accent); border-top: 2px solid var(--accent); }
      .rt-lock span:nth-child(3) { left: -1px; bottom: -1px; border-left: 2px solid var(--accent); border-bottom: 2px solid var(--accent); }
      .rt-lock span:nth-child(4) { right: -1px; bottom: -1px; border-right: 2px solid var(--accent); border-bottom: 2px solid var(--accent); }

      @media (max-width: 760px) { .rt, .rt-grid { display: none !important; } }

      /* ---- overlay nav ---- */
      .overlay {
        position: fixed;
        inset: 0;
        background: var(--ink);
        z-index: 60;
        display: flex;
        flex-direction: column;
        justify-content: center;
        padding: 0 8vw;
        clip-path: inset(0 0 100% 0);
        transition: clip-path .6s cubic-bezier(.76, 0, .24, 1);
      }
      .overlay--open { clip-path: inset(0 0 0 0); }
      .overlay__link {
        font-family: var(--font-display);
        font-weight: 800;
        font-size: clamp(40px, 11vw, 96px);
        line-height: 1.05;
        color: var(--bg);
        text-decoration: none;
        display: flex;
        align-items: baseline;
        gap: 20px;
        transition: color .15s;
      }
      .overlay__link:hover { color: var(--accent); }
      .overlay__num {
        font-family: var(--font-mono);
        font-size: 14px;
        color: var(--accent);
      }
    </style>
  </body>
</html>
