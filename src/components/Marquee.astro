---
interface Props {
  items: string[];
}
const { items } = Astro.props;
// Two identical copies; the track translates exactly -50%, so the second copy
// lands precisely where the first began — a seamless, infinite loop.
const copies = [0, 1];
---

<div class="marquee">
  <div class="marquee__track" aria-hidden="false">
    {
      copies.map(() => (
        <div class="marquee__group">
          {items.map((item) => (
            <>
              <span>{item}</span>
              <span class="marquee__sep">✦</span>
            </>
          ))}
        </div>
      ))
    }
  </div>
</div>
