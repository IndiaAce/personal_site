---
import Base from '../layouts/Base.astro';
import Marquee from '../components/Marquee.astro';
import { meta, experience, education, skills, intro } from '../data/profile';

const navTiles = [
  { num: '01', label: 'Résumé', href: '/resume' },
  { num: '02', label: 'Writing', href: '/blog' },
  { num: '03', label: 'GitHub', href: '/github' },
  { num: '04', label: 'Now', href: '/now' },
];

const marquee = ['M.Sc AI/ML', 'Threat Detection', 'B1 Français', 'Machine Learning'];

// Mobile résumé shows the two most recent roles inline; the rest live on /resume.
const mobileRoles = experience.slice(0, 2);
---

<Base>
  <!-- desktop: brutalist hero + tile nav -->
  <div class="desktop-only">
    <section class="home wrap">
      <h1 class="home__name">Luke<br />Wescott<span class="accent">.</span></h1>

      <p class="home__lede">
        Threat Detection Engineer at <span class="home__lede-em">Sublime Security</span>.
        I build a blend of ML and detection tools to help prevent bad guys from sending malicious email.
      </p>

      <div class="home__nav">
        {
          navTiles.map((t) => (
            <a class="tile" href={t.href} data-target={t.label}>
              <span class="tile__num">{t.num}</span>
              <span class="tile__label">{t.label}</span>
            </a>
          ))
        }
      </div>
    </section>

    <Marquee items={marquee} />
  </div>

  <!-- mobile: Paper "living résumé" -->
  <section class="m-section mr">
    <div class="mr__photo">
      <img src="/assets/luke.jpg" alt="Luke Wescott" width="1077" height="709" loading="eager" decoding="async" />
      <div class="mr__photo-tint"></div>
    </div>

    <div class="mr__kicker">LIVING RÉSUMÉ</div>
    <h1 class="mr__name">Luke<br />Wescott<span class="accent">.</span></h1>
    <p class="mr__bio">{intro}</p>

    <div class="mr__facts">
      {
        meta.map((f) => (
          <div class="mr__fact">
            <span class="mr__fact-k">{f.k}</span>
            {f.href ? (
              <a class="mr__fact-v mr__fact-link" href={f.href}>{f.v}</a>
            ) : (
              <span class="mr__fact-v">{f.v}</span>
            )}
          </div>
        ))
      }
    </div>

    <div class="mr__label">EXPERIENCE</div>
    {
      mobileRoles.map((e) => (
        <div class="mr__role">
          <div class="mr__role-head">
            <span class="mr__role-title">{e.role}</span>
            <span class="mr__role-period">{e.period}</span>
          </div>
          <div class="mr__role-org">{e.org}</div>
          <ul class="mr__bullets">
            {e.bullets.map((b) => <li>{b.short}</li>)}
          </ul>
        </div>
      ))
    }

    <div class="mr__label">EDUCATION</div>
    {
      education.map((ed) => (
        <div class="mr__edu">
          <div class="mr__edu-deg">{ed.deg}</div>
          <div class="mr__edu-sub">{ed.school} · {ed.sub}</div>
        </div>
      ))
    }

    <div class="mr__skills">
      {skills.map((s) => <span class="mr__pill">{s}</span>)}
    </div>

    <a class="mr__full" href="/resume">Full résumé →</a>
  </section>
</Base>

<style>
  .home {
    padding: 7vh 0 9vh;
    animation: rise .5s ease both;
  }

  .home__name {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(54px, 9.5vw, 142px);
    line-height: .88;
    letter-spacing: -.025em;
    color: var(--ink);
    margin: 0 0 28px;
  }

  .home__lede {
    max-width: 560px;
    margin: 0 0 44px;
    font-size: clamp(18px, 2.4vw, 23px);
    line-height: 1.55;
    color: var(--ink-soft);
  }
  .home__lede-em { color: var(--ink); font-weight: 600; }

  /* bordered nav grid */
  .home__nav {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    border: var(--border);
    max-width: 760px;
  }
  .home__nav .tile {
    border-right: var(--border);
    padding: 24px 20px;
  }
  .home__nav .tile:last-child { border-right: 0; }

  @media (max-width: 720px) {
    .home__nav { grid-template-columns: 1fr; }
    .home__nav .tile { border-right: 0; border-bottom: var(--border); }
    .home__nav .tile:last-child { border-bottom: 0; }
  }

  /* ---- mobile Paper résumé ---- */
  .mr__photo {
    position: relative;
    overflow: hidden;
    border: 1px solid var(--line);
    border-radius: 14px;
    aspect-ratio: 1077 / 709;
  }
  .mr__photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: grayscale(1) contrast(1.04);
  }
  .mr__photo-tint {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 58%, var(--accent));
    mix-blend-mode: multiply;
    opacity: .26;
  }
  .mr__kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .24em;
    color: var(--accent);
    margin: 24px 0 8px;
  }
  .mr__name {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 46px;
    line-height: .92;
    letter-spacing: -.02em;
    margin: 0;
    color: var(--ink);
  }
  .mr__bio {
    font-size: 16px;
    line-height: 1.6;
    color: var(--ink-soft);
    margin: 18px 0 0;
  }

  .mr__facts { margin-top: 26px; border-top: 1px solid var(--line); }
  .mr__fact {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 14px;
    padding: 13px 0;
    border-bottom: 1px solid var(--line);
    font-family: var(--font-mono);
    font-size: 12.5px;
  }
  .mr__fact-k { color: var(--muted); letter-spacing: .08em; }
  .mr__fact-v { color: var(--ink); text-align: right; word-break: break-word; }
  .mr__fact-link { text-decoration: none; }
  .mr__fact-link:hover { color: var(--accent); }

  .mr__label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .2em;
    color: var(--muted);
    margin: 30px 0 12px;
  }

  .mr__role { padding: 4px 0 18px; }
  .mr__role-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 10px;
  }
  .mr__role-title { font-size: 19px; font-weight: 600; color: var(--ink); }
  .mr__role-period {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
    white-space: nowrap;
  }
  .mr__role-org {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--accent);
    margin: 3px 0 9px;
  }
  .mr__bullets {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 7px;
  }
  .mr__bullets li {
    position: relative;
    padding-left: 16px;
    font-size: 14.5px;
    line-height: 1.5;
    color: var(--ink-soft);
  }
  .mr__bullets li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 9px;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--accent);
  }

  .mr__edu { padding: 4px 0 14px; }
  .mr__edu-deg { font-size: 16px; font-weight: 600; color: var(--ink); line-height: 1.3; }
  .mr__edu-sub {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--muted);
    margin-top: 3px;
  }

  .mr__skills { display: flex; flex-wrap: wrap; gap: 7px; margin-top: 6px; }
  .mr__pill {
    padding: 6px 12px;
    border: 1px solid var(--line);
    border-radius: 100px;
    font-size: 12px;
    font-family: var(--font-mono);
    color: var(--ink);
  }

  .mr__full {
    display: inline-block;
    margin-top: 24px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: .08em;
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid transparent;
  }
  .mr__full:hover { border-bottom-color: var(--accent); }
</style>
