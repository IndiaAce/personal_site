---
import Base from '../layouts/Base.astro';
import { getContributionSeries, type ContribData } from '../lib/github';

// ============================================================
// Real @IndiaAce data, fetched at BUILD time (no token needed):
//   • contribution calendar — github-contributions-api.jogruber.de
//     (reads the public profile graph; returns per-day count + level 0-4)
//   • profile + repos        — api.github.com REST (public, unauthenticated)
// If either fetch fails (offline / rate-limited), we fall back to a
// procedural heatmap so the build never breaks.
// ============================================================
const USER = 'IndiaAce';

type Cell = { level: number; count: number; date: string } | null;

let weeks: Cell[][] = [];
let total = 0;
let streak = 0;
let repoCount = 0;
let repos: { name: string; desc: string; lang: string; stars: number; url: string }[] = [];
let usingRealData = false;

// Monthly commit rhythm (portrait-native chart on mobile) — last 12 months.
let months: { label: string; count: number }[] = [];
const MONTH_LABELS = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

try {
  // --- contribution calendar ---
  const cont = await fetch(
    `https://github-contributions-api.jogruber.de/v4/${USER}?y=last`
  ).then((r) => {
    if (!r.ok) throw new Error('contrib ' + r.status);
    return r.json();
  });
  const days: { date: string; count: number; level: number }[] = cont.contributions;
  total = cont.total?.lastYear ?? days.reduce((a, d) => a + d.count, 0);

  // longest streak of consecutive active days
  let run = 0;
  for (const d of days) {
    if (d.count > 0) { run++; streak = Math.max(streak, run); } else run = 0;
  }

  // bucket daily counts into the last 12 calendar months
  const bucket: Record<string, number> = {};
  for (const d of days) {
    const key = d.date.slice(0, 7); // 'YYYY-MM'
    bucket[key] = (bucket[key] ?? 0) + d.count;
  }
  const last = new Date(days[days.length - 1].date + 'T00:00:00Z');
  for (let i = 11; i >= 0; i--) {
    const dt = new Date(Date.UTC(last.getUTCFullYear(), last.getUTCMonth() - i, 1));
    const key = `${dt.getUTCFullYear()}-${String(dt.getUTCMonth() + 1).padStart(2, '0')}`;
    months.push({ label: MONTH_LABELS[dt.getUTCMonth()], count: bucket[key] ?? 0 });
  }

  // grid: 7 rows (Sun→Sat), pad the first column to the first date's weekday
  const firstWeekday = new Date(days[0].date + 'T00:00:00Z').getUTCDay();
  const cells: Cell[] = [
    ...Array(firstWeekday).fill(null),
    ...days.map((d) => ({ level: d.level, count: d.count, date: d.date })),
  ];
  for (let i = 0; i < cells.length; i += 7) weeks.push(cells.slice(i, i + 7));

  // --- profile + repos ---
  const profile = await fetch(`https://api.github.com/users/${USER}`).then((r) => r.json());
  repoCount = profile.public_repos ?? 0;

  const repoData: any[] = await fetch(
    `https://api.github.com/users/${USER}/repos?per_page=100&sort=updated`
  ).then((r) => r.json());
  repos = repoData
    .filter((r) => !r.fork)
    // describable repos first, then by stars, then most recently pushed
    .sort((a, b) =>
      (b.description ? 1 : 0) - (a.description ? 1 : 0) ||
      b.stargazers_count - a.stargazers_count ||
      new Date(b.pushed_at).getTime() - new Date(a.pushed_at).getTime()
    )
    .slice(0, 3)
    .map((r) => ({
      name: r.name,
      desc: r.description || 'No description yet.',
      lang: r.language || '—',
      stars: r.stargazers_count,
      url: r.html_url,
    }));

  usingRealData = true;
} catch (err) {
  console.warn('[github] live fetch failed, using procedural fallback:', err);
  // procedural fallback (deterministic)
  weeks = [];
  total = 0;
  for (let w = 0; w < 52; w++) {
    const col: Cell[] = [];
    for (let d = 0; d < 7; d++) {
      const seed = Math.sin(w * 12.9898 + d * 78.233) * 43758.5453;
      const rnd = seed - Math.floor(seed);
      const wave = Math.sin(w / 7) * 0.3 + 0.4;
      let lvl = Math.max(0, Math.min(4, Math.floor((rnd * 0.7 + wave) * 5)));
      if (rnd < 0.18) lvl = 0;
      const count = lvl === 0 ? 0 : lvl * 3 + Math.floor(rnd * 4);
      total += count;
      col.push({ level: lvl, count, date: '' });
    }
    weeks.push(col);
  }
  streak = 47;
  repoCount = 30;
  months = [62, 70, 58, 66, 88, 74, 96, 120, 138, 196, 240, 210].map((count, i) => ({
    label: ['Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec', 'Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'][i],
    count,
  }));
  repos = [
    { name: 'sigma-tuner', desc: 'Auto-tunes detection thresholds against historical alert volume.', lang: 'Python', stars: 0, url: 'https://github.com/IndiaAce' },
    { name: 'embed-hunt', desc: 'Semantic search over threat intel using sentence embeddings.', lang: 'Python', stars: 0, url: 'https://github.com/IndiaAce' },
    { name: 'detection-prose', desc: 'Linter + style guide for human-readable detection rules.', lang: 'Go', stars: 0, url: 'https://github.com/IndiaAce' },
  ];
}

// Per-repo daily commit lines (needs GITHUB_TOKEN; null → heatmap fallback).
let chart: ContribData | null = null;
try {
  chart = await getContributionSeries();
} catch (err) {
  console.warn('[github] line-graph fetch failed, using heatmap:', err);
}
// When we have token-backed data, use its (private-inclusive) contribution total.
if (chart) total = chart.total;

const fmt = (n: number) => (n >= 1000 ? (n / 1000).toFixed(1) + 'k' : String(n));

const stats = [
  { n: fmt(total), l: 'CONTRIBUTIONS' },
  { n: String(streak), l: 'LONGEST STREAK' },
  { n: String(repoCount), l: 'PUBLIC REPOS' },
];

const legend = [0, 1, 2, 3, 4];

// monthly chart scaling + headline month (mobile rhythm chart)
const monthMax = Math.max(1, ...months.map((m) => m.count));
const peak = months.reduce(
  (a, m) => (m.count > a.count ? m : a),
  months[0] ?? { label: '', count: 0 }
);
---

<Base title="GitHub — Luke Wescott">
  <section class="gh wrap desktop-only">
    <div class="gh__head">
      <div>
        <div class="kicker">INDIAACE</div>
        <h1 class="gh__title">A year in commits</h1>
      </div>
      <div class="gh__stats">
        {
          stats.map((s) => (
            <div class="gh__stat">
              <div class="gh__stat-n">{s.n}</div>
              <div class="gh__stat-l">{s.l}</div>
            </div>
          ))
        }
      </div>
    </div>

    {
      chart ? (
        <div class="gh__board gh__board--chart">
          <div class="gh__chart-bar">
            <div class="gh__chart-cap">COMMITS PER DAY · BY REPO</div>
            <div class="gh__ranges" id="gh-ranges">
              <button class="gh__range" data-days="30">1M</button>
              <button class="gh__range" data-days="91">3M</button>
              <button class="gh__range" data-days="182">6M</button>
              <button class="gh__range gh__range--on" data-days="365">1Y</button>
            </div>
          </div>
          <div class="gh__chart" id="gh-chart" />
          <div class="gh__chart-legend" id="gh-legend">
            {chart.series.map((s) => (
              <button class="gh__lg" data-name={s.name} aria-pressed="true">
                <span class="gh__lg-swatch" style={`background:${s.color}`} />
                {s.name}
              </button>
            ))}
          </div>
          <script type="application/json" id="gh-data" set:html={JSON.stringify({ from: chart.from, to: chart.to, series: chart.series })} />
        </div>
      ) : (
        <div class="gh__board">
          <div class="gh__grid">
            {weeks.map((week) => (
              <div class="gh__col">
                {week.map((day) =>
                  day ? (
                    <div
                      class={`gh__cell heat-${day.level}`}
                      title={`${day.count} contributions${day.date ? ' · ' + day.date : ''}`}
                    />
                  ) : (
                    <div class="gh__cell gh__cell--empty" />
                  )
                )}
              </div>
            ))}
          </div>
          <div class="gh__legend">
            Less
            {legend.map((l) => <div class={`gh__legend-cell heat-${l}`} />)}
            More
          </div>
        </div>
      )
    }

    <div class="gh__repos">
      {
        repos.map((r) => (
          <a class="gh__repo" href={r.url} target="_blank" rel="noopener noreferrer" data-target={r.name}>
            <div class="gh__repo-name">
              <span class="gh__repo-dot" />
              {r.name}
            </div>
            <div class="gh__repo-desc">{r.desc}</div>
            <div class="gh__repo-meta">
              {r.lang} · ★ {r.stars}
            </div>
          </a>
        ))
      }
    </div>

    <a class="gh__profile" href={`https://github.com/${USER}`} target="_blank" rel="noopener noreferrer">
      View full profile on GitHub →
    </a>
  </section>

  <!-- mobile: Paper monthly commit rhythm -->
  <section class="m-section mg">
    <div class="mg__kicker">@INDIAACE</div>
    <h1 class="mg__title">A year in commits</h1>

    <div class="mg__stats">
      {
        stats.map((s) => (
          <div class="mg__stat">
            <div class="mg__stat-n">{s.n}</div>
            <div class="mg__stat-l">{s.l}</div>
          </div>
        ))
      }
    </div>

    <div class="mg__label">COMMITS BY MONTH · LAST 12</div>
    <div class="mg__panel">
      {
        months.map((m, i) => (
          <div class="mg__row">
            <div class="mg__month">{m.label}</div>
            <div class="mg__track">
              <div
                class="mg__bar"
                style={`width:${((m.count / monthMax) * 100).toFixed(1)}%;background:${i >= months.length - 3 ? 'var(--accent)' : 'var(--accent-soft)'}`}
              />
            </div>
            <div class="mg__count">{m.count}</div>
          </div>
        ))
      }
    </div>
    {peak.count > 0 && (
      <div class="mg__cap">{peak.label} was the heaviest build month of the year.</div>
    )}

    <a class="gh__profile mg__profile" href={`https://github.com/${USER}`} target="_blank" rel="noopener noreferrer">
      View full profile on GitHub →
    </a>
  </section>

  <script is:inline>
    (function () {
      var dataEl = document.getElementById('gh-data');
      var host = document.getElementById('gh-chart');
      if (!dataEl || !host) return;

      var DATA = JSON.parse(dataEl.textContent);
      var SVGNS = 'http://www.w3.org/2000/svg';
      var rangeDays = 365;
      var disabled = {}; // series name -> true when toggled off

      var css = getComputedStyle(document.documentElement);
      var LINE = (css.getPropertyValue('--line') || '#888').trim();
      var SOFT = (css.getPropertyValue('--ink-soft') || '#888').trim();

      function key(d) { return d.toISOString().slice(0, 10); }
      function addDays(d, n) { var x = new Date(d); x.setUTCDate(x.getUTCDate() + n); return x; }

      function el(name, attrs) {
        var n = document.createElementNS(SVGNS, name);
        for (var k in attrs) n.setAttribute(k, attrs[k]);
        return n;
      }

      function draw() {
        var W = host.clientWidth || 900;
        var H = 320;
        var padL = 40, padR = 14, padT = 14, padB = 26;
        var plotW = W - padL - padR;
        var plotH = H - padT - padB;

        var end = new Date(DATA.to + 'T00:00:00Z');
        var start = addDays(end, -(rangeDays - 1));

        // date axis
        var days = [];
        for (var i = 0; i < rangeDays; i++) days.push(addDays(start, i));

        var active = DATA.series.filter(function (s) { return !disabled[s.name]; });

        // max y across active series in range
        var maxY = 1;
        active.forEach(function (s) {
          for (var i = 0; i < days.length; i++) {
            var v = s.daily[key(days[i])] || 0;
            if (v > maxY) maxY = v;
          }
        });

        var xFor = function (i) { return padL + (rangeDays === 1 ? 0 : (i / (rangeDays - 1)) * plotW); };
        var yFor = function (v) { return padT + plotH - (v / maxY) * plotH; };

        var svg = el('svg', {
          viewBox: '0 0 ' + W + ' ' + H,
          width: '100%',
          height: H,
          preserveAspectRatio: 'none',
          role: 'img',
        });

        // horizontal gridlines + y labels
        var ticks = 4;
        for (var t = 0; t <= ticks; t++) {
          var val = Math.round((maxY * t) / ticks);
          var y = yFor(val);
          svg.appendChild(el('line', { x1: padL, y1: y, x2: W - padR, y2: y, stroke: LINE, 'stroke-width': 1, opacity: t === 0 ? 0.6 : 0.25 }));
          var lbl = el('text', { x: padL - 8, y: y + 3, 'text-anchor': 'end', fill: SOFT, 'font-size': 10, 'font-family': 'monospace' });
          lbl.textContent = String(val);
          svg.appendChild(lbl);
        }

        // month tick labels on x axis
        var lastMonth = -1;
        var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
        for (var i = 0; i < days.length; i++) {
          var m = days[i].getUTCMonth();
          if (m !== lastMonth) {
            lastMonth = m;
            var x = xFor(i);
            if (x < W - padR - 14) {
              var tl = el('text', { x: x, y: H - 8, 'text-anchor': 'middle', fill: SOFT, 'font-size': 10, 'font-family': 'monospace' });
              tl.textContent = months[m];
              svg.appendChild(tl);
            }
          }
        }

        // one polyline per active series
        active.forEach(function (s) {
          var pts = [];
          for (var i = 0; i < days.length; i++) {
            var v = s.daily[key(days[i])] || 0;
            pts.push(xFor(i).toFixed(1) + ',' + yFor(v).toFixed(1));
          }
          svg.appendChild(el('polyline', {
            points: pts.join(' '),
            fill: 'none',
            stroke: s.color,
            'stroke-width': 1.6,
            'stroke-linejoin': 'round',
            'stroke-linecap': 'round',
            opacity: 0.95,
          }));
        });

        host.innerHTML = '';
        host.appendChild(svg);
      }

      // range buttons
      var ranges = document.getElementById('gh-ranges');
      if (ranges) {
        ranges.addEventListener('click', function (e) {
          var b = e.target.closest('.gh__range');
          if (!b) return;
          rangeDays = parseInt(b.getAttribute('data-days'), 10);
          ranges.querySelectorAll('.gh__range').forEach(function (x) { x.classList.remove('gh__range--on'); });
          b.classList.add('gh__range--on');
          draw();
        });
      }

      // legend toggles
      var legend = document.getElementById('gh-legend');
      if (legend) {
        legend.addEventListener('click', function (e) {
          var b = e.target.closest('.gh__lg');
          if (!b) return;
          var name = b.getAttribute('data-name');
          disabled[name] = !disabled[name];
          b.classList.toggle('gh__lg--off', !!disabled[name]);
          b.setAttribute('aria-pressed', disabled[name] ? 'false' : 'true');
          draw();
        });
      }

      var rid;
      window.addEventListener('resize', function () { clearTimeout(rid); rid = setTimeout(draw, 120); });
      draw();
    })();
  </script>
</Base>

<style>
  .gh { padding: 54px 0 80px; max-width: 1180px; }
  .gh__head {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 36px;
    flex-wrap: wrap;
    gap: 20px;
  }
  .gh__title { font-size: clamp(40px, 6vw, 72px); line-height: .95; margin: 8px 0 0; }
  .gh__stats { display: flex; gap: 28px; }
  .gh__stat-n { font-family: var(--font-display); font-size: 40px; line-height: 1; }
  .gh__stat-l {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-soft);
    letter-spacing: .08em;
    margin-top: 4px;
  }

  .gh__board {
    border: var(--border);
    padding: 26px;
    background: var(--bg-elev);
    overflow-x: auto;
  }
  .gh__board--chart { overflow-x: visible; }

  .gh__chart-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    margin-bottom: 18px;
    flex-wrap: wrap;
  }
  .gh__chart-cap {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .12em;
    color: var(--ink-soft);
  }
  .gh__ranges { display: flex; gap: 6px; }
  .gh__range {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .06em;
    color: var(--ink-soft);
    background: transparent;
    border: 1px solid var(--line);
    padding: 5px 11px;
    cursor: pointer;
    transition: color .15s, border-color .15s, background .15s;
  }
  .gh__range:hover { color: var(--ink); }
  .gh__range--on {
    color: var(--bg);
    background: var(--accent);
    border-color: var(--accent);
  }

  .gh__chart { width: 100%; min-height: 320px; }
  .gh__chart svg { display: block; }

  .gh__chart-legend {
    display: flex;
    flex-wrap: wrap;
    gap: 8px 16px;
    margin-top: 18px;
  }
  .gh__lg {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink);
    background: transparent;
    border: 0;
    padding: 2px 0;
    cursor: pointer;
    transition: opacity .15s;
  }
  .gh__lg-swatch { width: 11px; height: 11px; border-radius: 2px; flex: none; }
  .gh__lg--off { opacity: .32; text-decoration: line-through; }

  .gh__grid { display: flex; gap: 3px; min-width: 720px; }
  .gh__col { display: flex; flex-direction: column; gap: 3px; }
  .gh__cell { width: 13px; height: 13px; border-radius: 3px; }
  .gh__cell--empty { background: transparent; }

  .gh__legend {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 8px;
    margin-top: 16px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-soft);
  }
  .gh__legend-cell { width: 11px; height: 11px; border-radius: 3px; }

  /* heat levels — recolor with theme via tokens */
  .heat-0 { background: var(--heat-0); }
  .heat-1 { background: var(--heat-1); }
  .heat-2 { background: var(--heat-2); }
  .heat-3 { background: var(--heat-3); }
  .heat-4 { background: var(--heat-4); }

  .gh__repos {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-top: 24px;
  }
  .gh__repo {
    border: 1px solid var(--line);
    padding: 20px;
    text-decoration: none;
    color: var(--ink);
    transition: border-color .15s;
  }
  .gh__repo:hover { border-color: var(--accent); }
  .gh__repo-name {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
    font-family: var(--font-mono);
    font-size: 14px;
    font-weight: 700;
  }
  .gh__repo-dot { width: 10px; height: 10px; border-radius: 50%; background: var(--accent); }
  .gh__repo-desc {
    font-size: 13.5px;
    line-height: 1.5;
    color: var(--ink-soft);
    margin-bottom: 12px;
  }
  .gh__repo-meta { font-family: var(--font-mono); font-size: 11px; color: var(--ink-soft); }

  .gh__profile {
    display: inline-block;
    margin-top: 28px;
    font-family: var(--font-mono);
    font-size: 13px;
    letter-spacing: .06em;
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid transparent;
  }
  .gh__profile:hover { border-bottom-color: var(--accent); }

  @media (max-width: 860px) {
    .gh__repos { grid-template-columns: 1fr; }
  }

  /* ---- mobile Paper monthly rhythm ---- */
  .mg__kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .24em;
    color: var(--accent);
    margin-bottom: 10px;
  }
  .mg__title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 40px;
    line-height: .96;
    letter-spacing: -.02em;
    margin: 0;
    color: var(--ink);
  }
  .mg__stats { display: flex; gap: 10px; margin: 22px 0 4px; }
  .mg__stat {
    flex: 1;
    border: 1px solid var(--line);
    border-radius: 12px;
    padding: 14px 12px;
    background: var(--bg-elev);
  }
  .mg__stat-n {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 28px;
    line-height: 1;
    color: var(--ink);
  }
  .mg__stat-l {
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: .06em;
    color: var(--muted);
    margin-top: 6px;
  }
  .mg__label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .16em;
    color: var(--muted);
    margin: 24px 0 6px;
  }
  .mg__panel {
    border: 1px solid var(--line);
    border-radius: 14px;
    background: var(--bg-elev);
    padding: 16px 16px 8px;
  }
  .mg__row { display: flex; align-items: center; gap: 12px; padding: 7px 0; }
  .mg__month {
    width: 34px;
    flex: none;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--muted);
  }
  .mg__track {
    flex: 1;
    height: 14px;
    border-radius: 5px;
    background: var(--inset);
    overflow: hidden;
  }
  .mg__bar { height: 100%; border-radius: 5px; }
  .mg__count {
    width: 30px;
    flex: none;
    text-align: right;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink);
  }
  .mg__cap {
    font-size: 12.5px;
    line-height: 1.5;
    color: var(--muted);
    margin-top: 12px;
    text-align: center;
  }
  .mg__profile { margin-top: 20px; }
</style>
