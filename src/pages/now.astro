---
import Base from '../layouts/Base.astro';

const updated = 'JUN 2026';

const nowItems = [
  {
    k: 'CURRENTLY',
    v: 'Detection Engineer II at Sublime Security — shipping ML-driven detection that catches what static rules miss, and helping grow the detection team.',
  },
  {
    k: 'LEARNING',
    v: 'French — pushing from B1 toward B2, one stubborn subjunctive at a time.',
  },
  {
    k: 'BUILDING',
    v: 'Detection-as-code tooling and ML pipelines that turn behavioral signal into high-fidelity coverage.',
  },
];

// ────────────────────────────────────────────────────────────────────────
// Currently listening — paste a Spotify track URL here to swap the song.
// Album art + title are pulled at build time from Spotify's public oEmbed.
// ────────────────────────────────────────────────────────────────────────
const SPOTIFY_TRACK_URL =
  'https://open.spotify.com/track/6vyiou1PHRHsdnQkCpqpnz';

const fmtTime = (s: number) =>
  `${Math.floor(s / 60)}:${String(Math.floor(s % 60)).padStart(2, '0')}`;

type NowPlaying = {
  title: string;
  art: string | null;
  url: string;
  pct: number;
  elapsed: string;
  duration: string;
};

let nowPlaying: NowPlaying | null = null;
try {
  const oe = await fetch(
    `https://open.spotify.com/oembed?url=${encodeURIComponent(SPOTIFY_TRACK_URL)}`
  ).then((r) => {
    if (!r.ok) throw new Error('oembed ' + r.status);
    return r.json();
  });

  // Deterministic "mid-song" position derived from the track id, so the bar is
  // stable per build but looks like the track is partway through.
  const id = SPOTIFY_TRACK_URL.split('/track/')[1]?.split('?')[0] ?? '';
  let h = 0;
  for (let i = 0; i < id.length; i++) h = (h * 31 + id.charCodeAt(i)) >>> 0;
  const pct = 0.22 + (h % 1000) / 1000 * 0.56; // 22%–78% through
  const total = 165 + (h % 95); // ~2:45–4:20 plausible runtime

  nowPlaying = {
    title: oe.title ?? 'Now playing',
    art: oe.thumbnail_url ?? null,
    url: SPOTIFY_TRACK_URL,
    pct,
    elapsed: fmtTime(total * pct),
    duration: fmtTime(total),
  };
} catch (err) {
  console.warn('[now] spotify oembed failed:', err);
}
---

<Base title="Now — Luke Wescott">
  <section class="now wrap desktop-only">
    <div class="now__kicker">
      04 — NOW <span class="now__updated">· UPDATED {updated}</span>
    </div>
    <h1 class="now__title">What I'm doing now</h1>
    <p class="now__lede">
      A snapshot of where my focus is right now.
    </p>

    <div class="now__list">
      {
        nowItems.map((i) => (
          <div class="now__row" data-target={i.k}>
            <div class="now__k">{i.k}</div>
            <div class="now__v">{i.v}</div>
          </div>
        ))
      }

      <div class="now__row" data-target="Listening">
        <div class="now__k">LISTENING</div>
        <div class="now__v">
          {
            nowPlaying ? (
              <a
                class="np"
                href={nowPlaying.url}
                target="_blank"
                rel="noopener noreferrer"
              >
                {nowPlaying.art && (
                  <img class="np__art" src={nowPlaying.art} alt="" width="64" height="64" />
                )}
                <span class="np__body">
                  <span class="np__label">CURRENTLY LISTENING TO:</span>
                  <span class="np__title">{nowPlaying.title}</span>
                  <span class="np__bar">
                    <span class="np__fill" style={`width:${(nowPlaying.pct * 100).toFixed(1)}%`} />
                  </span>
                  <span class="np__time">
                    <span>{nowPlaying.elapsed}</span>
                    <span>{nowPlaying.duration}</span>
                  </span>
                </span>
              </a>
            ) : (
              <a class="np np--bare" href={SPOTIFY_TRACK_URL} target="_blank" rel="noopener noreferrer">
                Open current track on Spotify ↗
              </a>
            )
          }
        </div>
      </div>
    </div>
  </section>

  <!-- mobile: Paper now -->
  <section class="m-section mn">
    <div class="mn__kicker">NOW · UPDATED {updated}</div>
    <h1 class="mn__title">What I'm doing now</h1>
    <div class="mn__list">
      {
        nowItems.map((i) => (
          <div class="mn__row">
            <div class="mn__k">{i.k}</div>
            <div class="mn__v">{i.v}</div>
          </div>
        ))
      }
      <div class="mn__row">
        <div class="mn__k">LISTENING</div>
        <div class="mn__v">
          {
            nowPlaying ? (
              <a class="np" href={nowPlaying.url} target="_blank" rel="noopener noreferrer">
                {nowPlaying.art && (
                  <img class="np__art" src={nowPlaying.art} alt="" width="64" height="64" />
                )}
                <span class="np__body">
                  <span class="np__label">CURRENTLY LISTENING TO:</span>
                  <span class="np__title">{nowPlaying.title}</span>
                  <span class="np__bar">
                    <span class="np__fill" style={`width:${(nowPlaying.pct * 100).toFixed(1)}%`} />
                  </span>
                  <span class="np__time">
                    <span>{nowPlaying.elapsed}</span>
                    <span>{nowPlaying.duration}</span>
                  </span>
                </span>
              </a>
            ) : (
              <a class="np np--bare" href={SPOTIFY_TRACK_URL} target="_blank" rel="noopener noreferrer">
                Open current track on Spotify ↗
              </a>
            )
          }
        </div>
      </div>
    </div>
  </section>
</Base>

<style>
  .now {
    padding: 6vh 0 12vh;
    max-width: 880px;
    animation: rise .5s ease both;
  }
  .now__kicker {
    display: flex;
    align-items: center;
    gap: 14px;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: .24em;
    color: var(--accent);
    margin-bottom: 12px;
  }
  .now__updated { color: var(--ink-soft); letter-spacing: .1em; }

  .now__title {
    font-size: clamp(42px, 6.5vw, 84px);
    line-height: .95;
    letter-spacing: -.015em;
    margin: 0 0 16px;
  }
  .now__lede {
    font-size: 18px;
    line-height: 1.6;
    color: var(--ink-soft);
    max-width: 560px;
    margin: 0 0 48px;
  }
  .now__em { color: var(--ink); }

  .now__list { display: flex; flex-direction: column; }
  .now__row {
    display: grid;
    grid-template-columns: 150px 1fr;
    gap: 24px;
    align-items: start;
    padding: 26px 4px;
    border-top: 1px solid var(--line);
    transition: background .15s;
  }
  .now__row:last-child { border-bottom: 1px solid var(--line); }
  .now__row:hover { background: var(--bg-elev); }
  .now__k {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: .14em;
    color: var(--accent);
    padding-top: 5px;
  }
  .now__v {
    font-size: clamp(18px, 2.2vw, 22px);
    line-height: 1.5;
    color: var(--ink);
  }

  /* now playing card */
  .np {
    display: flex;
    align-items: center;
    gap: 16px;
    text-decoration: none;
    color: var(--ink);
    max-width: 420px;
  }
  .np--bare {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--accent);
  }
  .np__art {
    width: 64px;
    height: 64px;
    flex: none;
    border: 1px solid var(--line);
    object-fit: cover;
    display: block;
  }
  .np__body { display: flex; flex-direction: column; gap: 6px; min-width: 0; flex: 1; }
  .np__label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .16em;
    color: var(--ink-soft);
  }
  .np__title {
    font-size: 16px;
    font-weight: 600;
    line-height: 1.2;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .np__bar {
    position: relative;
    height: 4px;
    border-radius: 2px;
    background: var(--line);
    overflow: hidden;
    margin-top: 2px;
  }
  .np__fill {
    position: absolute;
    inset: 0 auto 0 0;
    background: var(--accent);
  }
  .np__time {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-soft);
  }
  .np:hover .np__title { color: var(--accent); }

  @media (max-width: 600px) {
    .now__row { grid-template-columns: 1fr; gap: 8px; }
  }

  /* ---- mobile Paper now ---- */
  .mn__kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .24em;
    color: var(--accent);
    margin-bottom: 10px;
  }
  .mn__title {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 40px;
    line-height: .96;
    letter-spacing: -.02em;
    margin: 0;
    color: var(--ink);
  }
  .mn__list { margin-top: 22px; }
  .mn__row { padding: 18px 0; border-top: 1px solid var(--line); }
  .mn__row:last-child { border-bottom: 1px solid var(--line); }
  .mn__k {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .14em;
    color: var(--accent);
    margin-bottom: 8px;
  }
  .mn__v { font-size: 16.5px; line-height: 1.5; color: var(--ink); }
</style>
